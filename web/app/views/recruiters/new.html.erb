<% content_for :title, "Add a Recruiter — Recruiter Rankings" %>

<div style="max-width:560px; margin:0 auto; padding:48px 0 64px;">
  <h1 style="margin:0 0 8px;">Add a Recruiter</h1>
  <p style="color:var(--muted); margin:0 0 36px;">
    They'll be added to the directory and you'll go straight to the review form.
  </p>

  <% if @recruiter.errors.any? %>
    <div class="card" style="padding:16px 24px; margin-bottom:24px; border-left:3px solid var(--error, #c0392b);">
      <p style="margin:0 0 8px; font-weight:600; color:var(--error, #c0392b);">
        Please fix the following:
      </p>
      <ul style="margin:0; padding-left:1.2em; color:var(--error, #c0392b); font-size:0.9rem; line-height:1.8;">
        <% @recruiter.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @recruiter, url: recruiters_path, method: :post,
        style: "display:flex; flex-direction:column; gap:20px;" do |f| %>

    <div>
      <%= f.label :name, "Name *",
            style: "display:block; font-weight:600; margin-bottom:6px; font-size:0.9rem;" %>
      <%= f.text_field :name,
            placeholder: "e.g. Jane Smith",
            autocomplete: "off",
            required: true,
            style: "width:100%; box-sizing:border-box; padding:10px 14px; border-radius:8px; border:1px solid var(--border); background:var(--bg); color:var(--ink); font-size:1rem;" %>
    </div>

    <div>
      <%= f.label :company_name, "Company name (optional)",
            style: "display:block; font-weight:600; margin-bottom:6px; font-size:0.9rem;" %>
      <%= f.text_field :company_name,
            placeholder: "e.g. Acme Staffing",
            autocomplete: "off",
            style: "width:100%; box-sizing:border-box; padding:10px 14px; border-radius:8px; border:1px solid var(--border); background:var(--bg); color:var(--ink); font-size:1rem;" %>
    </div>

    <div>
      <%= f.label :linkedin_url, "LinkedIn URL (optional)",
            style: "display:block; font-weight:600; margin-bottom:6px; font-size:0.9rem;" %>
      <%= f.url_field :linkedin_url,
            placeholder: "https://linkedin.com/in/janesmith",
            autocomplete: "off",
            style: "width:100%; box-sizing:border-box; padding:10px 14px; border-radius:8px; border:1px solid var(--border); background:var(--bg); color:var(--ink); font-size:1rem;" %>
    </div>

    <div>
      <%= f.label :region, "Region (optional)",
            style: "display:block; font-weight:600; margin-bottom:6px; font-size:0.9rem;" %>
      <%= f.text_field :region,
            placeholder: "e.g. US – New York",
            autocomplete: "off",
            style: "width:100%; box-sizing:border-box; padding:10px 14px; border-radius:8px; border:1px solid var(--border); background:var(--bg); color:var(--ink); font-size:1rem;" %>
    </div>

    <div style="display:flex; gap:12px; align-items:center; margin-top:8px;">
      <%= f.submit "Add recruiter & write review",
            class: "cta",
            style: "margin-top:0;" %>
      <%= link_to "Cancel", new_global_review_path,
            style: "color:var(--muted); font-size:0.9rem;" %>
    </div>

  <% end %>
</div>
