<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Web" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Canonical and meta (fallbacks) %>
    <link rel="canonical" href="<%= canonical_url %>">
    <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'De‑identified recruiter quality signals with right‑of‑reply.' %>">
    <meta property="og:site_name" content="Recruiter Rankings">
    <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : 'Recruiter Rankings' %>">
    <meta property="og:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'De‑identified recruiter quality signals with right‑of‑reply.' %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta name="twitter:card" content="summary">

    <%= yield :head %>

    <%# ClerkJS — loads the Clerk frontend SDK for session management and auth UI.
        Only injected when CLERK_PUBLISHABLE_KEY is present (safe to omit in CI). %>
    <% if (clerk_js_url = Rails.application.config.clerk_js_url).present? %>
      <script nonce="<%= content_security_policy_nonce %>">
        var _personIcon = '<svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 17c0-3.314 3.134-6 7-6s7 2.686 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>';
        function initClerkNav() {
          window.Clerk.load({
            signInFallbackRedirectUrl: window.location.origin + '/',
            signUpFallbackRedirectUrl: window.location.origin + '/'
          }).then(function() {
            var auth = document.getElementById('clerk-nav-auth');
            if (!auth) return;
            if (window.Clerk.user) {
              var name = window.Clerk.user.firstName || (window.Clerk.user.emailAddresses[0] || {}).emailAddress || 'user';
              var settingsLink = document.createElement('a');
              settingsLink.href = '/settings';
              settingsLink.className = 'nav-link';
              settingsLink.title = 'Settings for ' + name;
              settingsLink.textContent = 'Settings';
              var signOutBtn = document.createElement('button');
              signOutBtn.className = 'nav-auth-btn nav-auth-btn--in';
              signOutBtn.title = 'Signed in as ' + name + ' \u2014 click to sign out';
              signOutBtn.setAttribute('aria-label', 'Sign out');
              signOutBtn.innerHTML = _personIcon;
              signOutBtn.onclick = function() { window.Clerk.signOut().then(function(){location.reload()}); return false; };
              auth.appendChild(settingsLink);
              auth.appendChild(signOutBtn);
            } else {
              var signInBtn = document.createElement('button');
              signInBtn.className = 'nav-auth-btn';
              signInBtn.title = 'Sign in';
              signInBtn.setAttribute('aria-label', 'Sign in');
              signInBtn.innerHTML = _personIcon;
              signInBtn.onclick = function() { window.Clerk.redirectToSignIn({redirectUrl: window.location.href}); return false; };
              auth.appendChild(signInBtn);
            }
          });
        }
      </script>
      <script async crossorigin="anonymous"
        nonce="<%= content_security_policy_nonce %>"
        data-clerk-publishable-key="<%= h ENV['CLERK_PUBLISHABLE_KEY'] %>"
        src="<%= h clerk_js_url %>"
        id="clerk-js-script"
        type="text/javascript"></script>
      <script nonce="<%= content_security_policy_nonce %>">
        document.getElementById('clerk-js-script').addEventListener('load', initClerkNav);
      </script>
    <% end %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="shortcut icon" href="/favicon.ico">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app %>
    <%# Include the Jekyll site stylesheet to unify theme %>
    <link rel="stylesheet" href="/assets/style.css" />
    <script nonce="<%= content_security_policy_nonce %>">
      (function(){
        try{
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        }catch(e){ document.documentElement.setAttribute('data-theme','dark'); }
      })();
    </script>
  </head>

  <body>
    <a href="#main-content" class="skip-link"><%= t('nav.skip_to_content', default: 'Skip to content') %></a>
    <header class="site-header">
      <nav class="container nav">
        <a class="brand" href="/">
          <img src="/logo.svg" alt="" class="nav-logo" width="32" height="32" aria-hidden="true">
          Recruiter Rankings
        </a>
        <div class="nav-actions">
          <a href="/search" class="nav-link"><%= t('nav.search', default: 'Search') %></a>
          <a href="/reviews/new" class="nav-link-cta">Submit Review</a>
          <div id="clerk-nav-auth"></div>
          <button class="theme-toggle" aria-label="Toggle theme" title="Toggle theme"></button>
          <button class="hamburger" id="nav-hamburger" aria-label="Menu" aria-expanded="false" aria-controls="nav-drawer">&#9776;</button>
        </div>
      </nav>
      <div id="nav-drawer" class="nav-drawer" hidden>
        <a href="/companies?type=recruiting">Recruiting Companies</a>
        <a href="/companies?type=hiring">Hiring Companies</a>
        <hr>
        <a href="/about"><%= t('nav.about') %></a>
        <a href="/policies"><%= t('nav.policies', default: 'Policies') %></a>
        <hr>
        <a href="/admin">Moderator Dashboard</a>
        <a href="/identity_verifications/new">Register / Verify</a>
      </div>
    </header>

    <main class="container" id="main-content">
      <% flash.each do |type, msg| %>
        <div class="alert alert-<%= type == 'notice' ? 'info' : 'danger' %>">
          <%= msg %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="site-footer container">
      <p class="text-muted text-sm">
        &copy; <%= Time.current.year %>
        <a href="https://recruiter-rankings.com" style="color:var(--muted);">Recruiter Rankings</a>,
        a spin-out from <a href="https://www.5l-labs.com" style="color:var(--muted);">5L-Labs</a>.
        All rights reserved.
        Identity services provided by <a href="https://clerk.com" style="color:var(--muted);">Clerk</a>.
      </p>
    </footer>
    <script src="/assets/theme.js" nonce="<%= content_security_policy_nonce %>"></script>
    <script nonce="<%= content_security_policy_nonce %>">
      (function(){
        var btn = document.getElementById('nav-hamburger');
        var drawer = document.getElementById('nav-drawer');
        if (!btn || !drawer) return;
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          var hidden = drawer.hasAttribute('hidden');
          if (hidden) { drawer.removeAttribute('hidden'); btn.setAttribute('aria-expanded','true'); }
          else { drawer.setAttribute('hidden',''); btn.setAttribute('aria-expanded','false'); }
        });
        document.addEventListener('click', function(e) {
          if (!btn.contains(e.target) && !drawer.contains(e.target)) {
            drawer.setAttribute('hidden','');
            btn.setAttribute('aria-expanded','false');
          }
        });
      })();
    </script>

  </body>
</html>
