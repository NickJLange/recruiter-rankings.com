# Copy to .env.local (git-ignored) and fill in values.

# -----------------------------------------------------------------------
# Render production database
# Get from: Render Dashboard → your PostgreSQL service → External Database URL
# -----------------------------------------------------------------------
DATABASE_URL=postgres://user:pass@host.oregon-postgres.render.com/dbname

# -----------------------------------------------------------------------
# Cloudflare R2
# Get from: Cloudflare Dashboard → R2 → Manage R2 API tokens
# -----------------------------------------------------------------------
R2_BUCKET=recruiter-rankings-com-backups
R2_ENDPOINT_URL=https://83ea2ae765d48de9f50ec024976dd319.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------
# Retention (optional — default 30 days)
# -----------------------------------------------------------------------
# RETENTION_DAYS=30

# -----------------------------------------------------------------------
# Health check (optional but recommended)
# 1. Sign up free at https://healthchecks.io
# 2. Create a check: period=1d, grace=2h
# 3. Paste the ping URL below
# If no ping is received within grace period, healthchecks.io emails you.
# -----------------------------------------------------------------------
# HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here

# -----------------------------------------------------------------------
# Restore mode only (docker compose run --rm backup restore [latest|filename])
# Set TARGET_DB_URL to the new Render DB URL after recreation.
# -----------------------------------------------------------------------
# TARGET_DB_URL=postgres://user:pass@host.oregon-postgres.render.com/newdbname

# -----------------------------------------------------------------------
# Render free-DB lifecycle restore
# (docker compose run --rm backup render-restore)
#
# RENDER_OWNER_ID:   Render dashboard URL → your user path → usr-XXXX
# RENDER_SERVICE_ID: Web service URL → srv-XXXX
# -----------------------------------------------------------------------
# RENDER_API_KEY=
# RENDER_OWNER_ID=usr-
# RENDER_SERVICE_ID=srv-
# RENDER_REGION=oregon
